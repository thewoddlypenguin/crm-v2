# ─── Database ──────────────────────────────────────────────────────────────
# Use your Neon PostgreSQL URL, or any PostgreSQL connection string
DATABASE_URL=postgresql://user:pass@host:5432/dbname?sslmode=require

# ─── Auth ──────────────────────────────────────────────────────────────────
# Change this to a long random string for production (min 32 chars)
JWT_SECRET=change-me-to-a-long-random-string

# ─── Public Lead Intake ────────────────────────────────────────────────────
# API key for the public lead intake endpoint (POST /api/public/leads)
CRM_PUBLIC_API_KEY=your-api-key-here

# Optional: email of the user who owns publicly-submitted leads
# CRM_OWNER_EMAIL=you@example.com

# ─── App ───────────────────────────────────────────────────────────────────
# Port for the FastAPI backend (default 8000)
APP_PORT=8000
