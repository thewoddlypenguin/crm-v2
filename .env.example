# ── Required ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://leverage:yourpassword@db:5432/leveragecrm
JWT_SECRET=replace-me-with-output-of-python3-c-import-secrets-print-secrets-token-hex-32

# ── Auth & Security ───────────────────────────────────────────────────────────
# Set to false after creating your account
REGISTRATION_ENABLED=true
# Lock CORS to your domain in production (comma-separated)
# CORS_ORIGINS=https://crm.example.com

# ── Email Providers (set only the one you're using) ───────────────────────────
# RESEND_API_KEY=re_...
# SENDGRID_API_KEY=SG....
# POSTMARK_SERVER_TOKEN=...
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=user@example.com
# SMTP_PASSWORD=...
# SMTP_USE_TLS=true

# ── Seeder ────────────────────────────────────────────────────────────────────
# Email of the owner account — used by seed.py to assign demo data
# CRM_OWNER_EMAIL=you@example.com
